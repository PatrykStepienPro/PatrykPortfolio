@inject IJSRuntime JS
@inject LanguageService LangSvc
@implements IDisposable

<nav class="nav-container container-fluid">
    <a class="nav-brand" href="#hero" @onclick='() => ScrollTo("hero")'>
        PS<span class="nav-brand-dot">.</span>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links">
        <li><a href="#about" @onclick='() => ScrollTo("about")'>@LangSvc.Get("nav.about")</a></li>
        <li><a href="#techstack" @onclick='() => ScrollTo("techstack")'>@LangSvc.Get("nav.techstack")</a></li>
        <li><a href="#projects" @onclick='() => ScrollTo("projects")'>@LangSvc.Get("nav.projects")</a></li>
        <li><a href="#experience" @onclick='() => ScrollTo("experience")'>@LangSvc.Get("nav.experience")</a></li>
        <li><a href="#education" @onclick='() => ScrollTo("education")'>@LangSvc.Get("nav.education")</a></li>
        <li><a href="#contact" @onclick='() => ScrollTo("contact")' class="nav-cta">@LangSvc.Get("nav.contact")</a></li>
        <li>
            <button class="lang-switcher" @onclick="ToggleLang" aria-label="Switch language">
                @(LangSvc.Current == Lang.En ? "PL" : "EN")
            </button>
        </li>
    </ul>

    <!-- Mobile hamburger -->
    <div class="nav-right-mobile">
        <button class="lang-switcher lang-switcher-mobile" @onclick="ToggleLangMobile" aria-label="Switch language">
            @(LangSvc.Current == Lang.En ? "PL" : "EN")
        </button>
        <button class="nav-hamburger" @onclick="ToggleMenu" aria-label="Toggle navigation">
            <span class="@(menuOpen ? "bar bar-open-1" : "bar")"></span>
            <span class="@(menuOpen ? "bar bar-open-2" : "bar")"></span>
            <span class="@(menuOpen ? "bar bar-open-3" : "bar")"></span>
        </button>
    </div>
</nav>

<!-- Mobile dropdown -->
@if (menuOpen)
{
    <div class="nav-mobile-menu">
        <ul>
            <li><a href="#about" @onclick='() => MobileScrollTo("about")'>@LangSvc.Get("nav.about")</a></li>
            <li><a href="#techstack" @onclick='() => MobileScrollTo("techstack")'>@LangSvc.Get("nav.techstack")</a></li>
            <li><a href="#projects" @onclick='() => MobileScrollTo("projects")'>@LangSvc.Get("nav.projects")</a></li>
            <li><a href="#experience" @onclick='() => MobileScrollTo("experience")'>@LangSvc.Get("nav.experience")</a></li>
            <li><a href="#education" @onclick='() => MobileScrollTo("education")'>@LangSvc.Get("nav.education")</a></li>
            <li><a href="#contact" @onclick='() => MobileScrollTo("contact")'>@LangSvc.Get("nav.contact")</a></li>
        </ul>
    </div>
}

@code {
    private bool menuOpen = false;

    protected override void OnInitialized() => LangSvc.OnChange += StateHasChanged;
    public void Dispose() => LangSvc.OnChange -= StateHasChanged;

    private void ToggleMenu() => menuOpen = !menuOpen;

    private async Task ScrollTo(string id)
        => await JS.InvokeVoidAsync("scrollToSection", id);

    private async Task MobileScrollTo(string id)
    {
        menuOpen = false;
        await JS.InvokeVoidAsync("scrollToSection", id);
    }

    private async Task ToggleLang()
        => await LangSvc.SetLanguageAsync(LangSvc.Current == Lang.En ? Lang.Pl : Lang.En);

    private async Task ToggleLangMobile()
        => await LangSvc.SetLanguageAsync(LangSvc.Current == Lang.En ? Lang.Pl : Lang.En);
}
