@inject IJSRuntime JS

<nav class="nav-container container-fluid">
    <a class="nav-brand" href="#hero" @onclick='() => ScrollTo("hero")'>
        PS<span class="nav-brand-dot">.</span>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links">
        <li><a href="#about" @onclick='() => ScrollTo("about")'>About</a></li>
        <li><a href="#techstack" @onclick='() => ScrollTo("techstack")'>Tech Stack</a></li>
        <li><a href="#projects" @onclick='() => ScrollTo("projects")'>Projects</a></li>
        <li><a href="#experience" @onclick='() => ScrollTo("experience")'>Experience</a></li>
        <li><a href="#contact" @onclick='() => ScrollTo("contact")' class="nav-cta">Contact</a></li>
    </ul>

    <!-- Mobile hamburger -->
    <button class="nav-hamburger" @onclick="ToggleMenu" aria-label="Toggle navigation">
        <span class="@(menuOpen ? "bar bar-open-1" : "bar")"></span>
        <span class="@(menuOpen ? "bar bar-open-2" : "bar")"></span>
        <span class="@(menuOpen ? "bar bar-open-3" : "bar")"></span>
    </button>
</nav>

<!-- Mobile dropdown -->
@if (menuOpen)
{
    <div class="nav-mobile-menu">
        <ul>
            <li><a href="#about" @onclick='() => MobileScrollTo("about")'>About</a></li>
            <li><a href="#techstack" @onclick='() => MobileScrollTo("techstack")'>Tech Stack</a></li>
            <li><a href="#projects" @onclick='() => MobileScrollTo("projects")'>Projects</a></li>
            <li><a href="#experience" @onclick='() => MobileScrollTo("experience")'>Experience</a></li>
            <li><a href="#contact" @onclick='() => MobileScrollTo("contact")'>Contact</a></li>
        </ul>
    </div>
}

@code {
    private bool menuOpen = false;

    private void ToggleMenu()
    {
        menuOpen = !menuOpen;
    }

    private async Task ScrollTo(string id)
    {
        await JS.InvokeVoidAsync("scrollToSection", id);
    }

    private async Task MobileScrollTo(string id)
    {
        menuOpen = false;
        await JS.InvokeVoidAsync("scrollToSection", id);
    }
}
