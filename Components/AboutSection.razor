@inject LanguageService LangSvc
@implements IDisposable

<section class="section section-alt" id="about">
    <div class="container">
        <h2 class="section-title">@LangSvc.Get("about.title")</h2>
        <div class="section-title-line"></div>

        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <p class="about-bio">
                    @LangSvc.Get("about.bio1.start")<strong>Blazor WebAssembly</strong>@LangSvc.Get("about.bio1.end")
                </p>
                <p class="about-bio">@LangSvc.Get("about.bio2")</p>
                <div class="about-facts">
                    <div class="fact-item">
                        <span class="fact-icon">&#x1F4CD;</span>
                        <span>@LangSvc.Get("about.fact.location")</span>
                    </div>
                    <div class="fact-item">
                        <span class="fact-icon">&#x1F4BB;</span>
                        <span>@LangSvc.Get("about.fact.remote")</span>
                    </div>
                    <div class="fact-item">
                        <span class="fact-icon">&#x1F393;</span>
                        <span>@LangSvc.Get("about.fact.edu")</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 d-flex justify-content-center">
                <div class="about-portrait">
                    <div class="portrait-placeholder">
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                        <p>@LangSvc.Get("about.photo")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    protected override void OnInitialized() => LangSvc.OnChange += StateHasChanged;
    public void Dispose() => LangSvc.OnChange -= StateHasChanged;
}
