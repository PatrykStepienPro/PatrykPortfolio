@inject LanguageService LangSvc
@implements IDisposable

<section class="section" id="techstack">
    <div class="container">
        <h2 class="section-title">@LangSvc.Get("techstack.title")</h2>
        <div class="section-title-line"></div>

        @foreach (var group in GetTechGroups())
        {
            <div class="tech-group">
                <h3 class="tech-group-title">@group.Category</h3>
                <div class="tech-badges">
                    @foreach (var tech in group.Items)
                    {
                        <span class="tech-badge">@tech</span>
                    }
                </div>
            </div>
        }
    </div>
</section>

@code {
    private record TechGroup(string Category, string[] Items);

    protected override void OnInitialized() => LangSvc.OnChange += StateHasChanged;
    public void Dispose() => LangSvc.OnChange -= StateHasChanged;

    private TechGroup[] GetTechGroups() =>
    [
        new(LangSvc.Get("techstack.cat.languages"),     ["C#", "TypeScript", "SQL", "HTML", "CSS"]),
        new(LangSvc.Get("techstack.cat.frameworks"),    ["Blazor WebAssembly", "ASP.NET Core", ".NET 8 / .NET 10", "Entity Framework Core", "SignalR"]),
        new(LangSvc.Get("techstack.cat.databases"),     ["PostgreSQL", "SQL Server", "SQLite", "Redis"]),
        new(LangSvc.Get("techstack.cat.tools"),         ["Git", "GitHub Actions", "Docker", "Azure", "Rider / VS Code"]),
        new(LangSvc.Get("techstack.cat.architecture"),  ["Clean Architecture", "CQRS", "REST", "Domain-Driven Design"]),
    ];
}
