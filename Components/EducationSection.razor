@inject LanguageService LangSvc
@implements IDisposable

<section class="section" id="education">
    <div class="container">
        <h2 class="section-title">@LangSvc.Get("education.title")</h2>
        <div class="section-title-line"></div>

        <div class="edu-list">
            @foreach (var item in GetEducation())
            {
                <div class="edu-item card-dark">
                    <div class="edu-header">
                        <div class="edu-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                            </svg>
                        </div>
                        <div class="edu-info">
                            <h3 class="edu-degree">@item.Degree</h3>
                            <p class="edu-school">@item.School</p>
                        </div>
                        <span class="edu-period">@item.Period</span>
                    </div>
                    @if (!string.IsNullOrEmpty(item.Description))
                    {
                        <p class="edu-description">@item.Description</p>
                    }
                    @if (item.Tags.Length > 0)
                    {
                        <div class="edu-tags">
                            @foreach (var tag in item.Tags)
                            {
                                <span class="edu-tag">@tag</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</section>

@code {
    private record EducationItem(string Degree, string School, string Period, string Description, string[] Tags);

    protected override void OnInitialized() => LangSvc.OnChange += StateHasChanged;
    public void Dispose() => LangSvc.OnChange -= StateHasChanged;

    private EducationItem[] GetEducation() =>
    [
        new(
            LangSvc.Get("education.degree1"),
            LangSvc.Get("education.school1"),
            LangSvc.Get("education.period1"),
            LangSvc.Get("education.desc1"),
            ["C#", ".NET", "Blazor", "SQL"]
        ),
        new(
            LangSvc.Get("education.degree2"),
            LangSvc.Get("education.school2"),
            LangSvc.Get("education.period2"),
            LangSvc.Get("education.desc2"),
            ["C#", ".NET", "Algorytmy", "Bazy danych"]
        ),
    ];
}
