@inject LanguageService LangSvc
@implements IDisposable

<section class="section section-alt" id="projects">
    <div class="container">
        <h2 class="section-title">@LangSvc.Get("projects.title")</h2>
        <div class="section-title-line"></div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var project in GetProjects())
            {
                <div class="col">
                    <div class="card-dark project-card h-100">
                        <div class="project-card-body">
                            <div class="project-header">
                                <svg class="project-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                                    <path d="M8 10h8M8 14h4"/>
                                </svg>
                                <div class="project-links">
                                    @if (!string.IsNullOrEmpty(project.GitHubUrl))
                                    {
                                        <a href="@project.GitHubUrl" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="project-link">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                                            </svg>
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(project.LiveUrl))
                                    {
                                        <a href="@project.LiveUrl" target="_blank" rel="noopener noreferrer" aria-label="Live demo" class="project-link">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                                <polyline points="15 3 21 3 21 9"/>
                                                <line x1="10" y1="14" x2="21" y2="3"/>
                                            </svg>
                                        </a>
                                    }
                                </div>
                            </div>
                            <h3 class="project-title">@project.Name</h3>
                            <p class="project-description">@project.Description</p>
                            <div class="project-tags">
                                @foreach (var tag in project.Tags)
                                {
                                    <span class="project-tag">@tag</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private record ProjectItem(string Name, string Description, string[] Tags, string GitHubUrl = "", string LiveUrl = "");

    protected override void OnInitialized() => LangSvc.OnChange += StateHasChanged;
    public void Dispose() => LangSvc.OnChange -= StateHasChanged;

    private ProjectItem[] GetProjects() =>
    [
        new(
            LangSvc.Get("projects.portfolio.name"),
            LangSvc.Get("projects.portfolio.desc"),
            ["Blazor WASM", ".NET 10", "GitHub Actions", "CSS"],
            "https://github.com/patryks/portfolio"
        ),
        new(
            LangSvc.Get("projects.loyalty.name"),
            LangSvc.Get("projects.loyalty.desc"),
            ["Blazor Server", "ASP.NET Core", "MudBlazor", "MS SQL Server", "EF Core"]
        ),
    ];
}
