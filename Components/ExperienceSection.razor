@inject LanguageService LangSvc
@implements IDisposable

<section class="section" id="experience">
    <div class="container">
        <h2 class="section-title">@LangSvc.Get("experience.title")</h2>
        <div class="section-title-line"></div>

        <div class="timeline">
            @foreach (var item in GetExperience())
            {
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content card-dark">
                        <div class="timeline-header">
                            <div>
                                <h3 class="timeline-role">@item.Role</h3>
                                <p class="timeline-company">@item.Company</p>
                            </div>
                            <span class="timeline-period">@item.Period</span>
                        </div>
                        <ul class="timeline-bullets">
                            @foreach (var bullet in item.Bullets)
                            {
                                <li>@bullet</li>
                            }
                        </ul>
                        <div class="timeline-tags">
                            @foreach (var tag in item.Tags)
                            {
                                <span class="project-tag">@tag</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private record ExperienceItem(string Role, string Company, string Period, string[] Bullets, string[] Tags);

    protected override void OnInitialized() => LangSvc.OnChange += StateHasChanged;
    public void Dispose() => LangSvc.OnChange -= StateHasChanged;

    private ExperienceItem[] GetExperience() =>
    [
        new(
            LangSvc.Get("experience.role1"),
            LangSvc.Get("experience.company1"),
            LangSvc.Get("experience.period1"),
            [
                LangSvc.Get("experience.bullet1.1"),
                LangSvc.Get("experience.bullet1.2"),
                LangSvc.Get("experience.bullet1.3"),
            ],
            ["Blazor", "ASP.NET Core", "Azure", "EF Core"]
        ),
        new(
            LangSvc.Get("experience.role2"),
            LangSvc.Get("experience.company2"),
            LangSvc.Get("experience.period2"),
            [
                LangSvc.Get("experience.bullet2.1"),
                LangSvc.Get("experience.bullet2.2"),
                LangSvc.Get("experience.bullet2.3"),
            ],
            ["Blazor Server", "SQL Server", ".NET 6"]
        ),
    ];
}
