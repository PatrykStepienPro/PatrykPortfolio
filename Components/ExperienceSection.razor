<section class="section" id="experience">
    <div class="container">
        <h2 class="section-title">Experience</h2>
        <div class="section-title-line"></div>

        <div class="timeline">
            @foreach (var item in Experience)
            {
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content card-dark">
                        <div class="timeline-header">
                            <div>
                                <h3 class="timeline-role">@item.Role</h3>
                                <p class="timeline-company">@item.Company</p>
                            </div>
                            <span class="timeline-period">@item.Period</span>
                        </div>
                        <ul class="timeline-bullets">
                            @foreach (var bullet in item.Bullets)
                            {
                                <li>@bullet</li>
                            }
                        </ul>
                        <div class="timeline-tags">
                            @foreach (var tag in item.Tags)
                            {
                                <span class="project-tag">@tag</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private record ExperienceItem(string Role, string Company, string Period, string[] Bullets, string[] Tags);

    private static readonly ExperienceItem[] Experience =
    [
        new(
            ".NET Developer",
            "Company Name",
            "2023 — Present",
            [
                "Developed and maintained Blazor WebAssembly applications for enterprise clients.",
                "Designed RESTful APIs with ASP.NET Core and Entity Framework Core.",
                "Implemented CI/CD pipelines using GitHub Actions and Azure DevOps.",
            ],
            ["Blazor", "ASP.NET Core", "Azure", "EF Core"]
        ),
        new(
            "Junior .NET Developer",
            "Previous Company",
            "2021 — 2023",
            [
                "Built internal tooling with Blazor Server and SQL Server.",
                "Participated in code reviews and contributed to architecture discussions.",
                "Improved application performance by optimizing EF Core queries.",
            ],
            ["Blazor Server", "SQL Server", ".NET 6"]
        ),
    ];
}
