@if (Project.Screenshots.Length > 0)
{
    <div class="card-dark project-card">
        <table class="project-card-table">
            <tr>
                <td class="project-card-text-cell">
                    @CardBody
                </td>
                <td class="project-card-slider-cell">
                    <div class="screenshot-slider">
                        <img src="@Project.Screenshots[_activeIndex]"
                             alt="@Project.Name screenshot @(_activeIndex + 1)"
                             class="screenshot-img" />
                        @if (Project.Screenshots.Length > 1)
                        {
                            <button class="slider-btn slider-btn-prev" @onclick="Prev" aria-label="Previous">&#8249;</button>
                            <button class="slider-btn slider-btn-next" @onclick="Next" aria-label="Next">&#8250;</button>
                            <div class="slider-dots">
                                @for (int i = 0; i < Project.Screenshots.Length; i++)
                                {
                                    int idx = i;
                                    <button class="slider-dot @(_activeIndex == idx ? "active" : "")"
                                            @onclick="() => _activeIndex = idx"
                                            aria-label="Screenshot @(idx + 1)" />
                                }
                            </div>
                        }
                    </div>
                </td>
            </tr>
        </table>
    </div>
}
else
{
    <div class="card-dark project-card pa-rem15">
        <div class="project-card-body">
            @CardBody
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public ProjectsSection.ProjectItem Project { get; set; } = default!;
    [Parameter, EditorRequired] public RenderFragment CardBody { get; set; } = default!;

    private int _activeIndex;

    private void Prev() => _activeIndex = (_activeIndex - 1 + Project.Screenshots.Length) % Project.Screenshots.Length;
    private void Next() => _activeIndex = (_activeIndex + 1) % Project.Screenshots.Length;
}
